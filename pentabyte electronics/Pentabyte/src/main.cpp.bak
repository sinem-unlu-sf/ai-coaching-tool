#include <Arduino.h>
#include <driver/i2s.h>
#include <math.h>

// --- SPEAKER PINS ---
#define I2S_BCK  26
#define I2S_LRC  27
#define I2S_DOUT 25

// --- AUDIO SETTINGS ---
#define SAMPLE_RATE 44100 
#define WAVE_FREQ_HZ 440  // 440Hz = A4 Note
#define VOLUME 0.1        // 0.0 to 1.0 (Be careful, it gets LOUD)

void setup() {
  Serial.begin(115200);

  // 1. Configure I2S Driver
  i2s_config_t i2s_config = {
    .mode = (i2s_mode_t)(I2S_MODE_MASTER | I2S_MODE_TX), // Transmit only
    .sample_rate = SAMPLE_RATE,
    .bits_per_sample = I2S_BITS_PER_SAMPLE_16BIT,
    .channel_format = I2S_CHANNEL_FMT_RIGHT_LEFT, // Stereo
    .communication_format = I2S_COMM_FORMAT_STAND_I2S,
    .intr_alloc_flags = ESP_INTR_FLAG_LEVEL1,
    .dma_buf_count = 8,
    .dma_buf_len = 64,
    .use_apll = false
  };

  // 2. Configure Pins
  i2s_pin_config_t pin_config = {
    .bck_io_num = I2S_BCK,
    .ws_io_num = I2S_LRC,
    .data_out_num = I2S_DOUT,
    .data_in_num = I2S_PIN_NO_CHANGE // Not recording
  };

  // 3. Install and Start
  i2s_driver_install(I2S_NUM_0, &i2s_config, 0, NULL);
  i2s_set_pin(I2S_NUM_0, &pin_config);
  
  Serial.println("Speaker Initialized. Tone starting...");
}

void loop() {
  // Generate a Sine Wave
  // We need to fill the buffer with data constantly
  
  int samples = 1024;
  size_t bytes_written;
  int16_t buffer[samples * 2]; // Stereo buffer (*2)

  // Math to create the wave
  static float phase = 0;
  float phaseIncrement = (2 * PI * WAVE_FREQ_HZ) / SAMPLE_RATE;

  for (int i = 0; i < samples; i++) {
    // Calculate the wave height (-1 to +1)
    float wave = sin(phase);
    phase += phaseIncrement;
    if (phase > 2 * PI) phase -= 2 * PI;

    // Scale to 16-bit integer (Volume control)
    int16_t audioValue = (int16_t)(wave * 32767 * VOLUME);

    // Fill Left and Right channels
    buffer[i * 2] = audioValue;     // Left
    buffer[i * 2 + 1] = audioValue; // Right
  }

  // Send to Speaker
  i2s_write(I2S_NUM_0, buffer, sizeof(buffer), &bytes_written, portMAX_DELAY);
}